  "reference": {
    "pmid": "6757410",
    "doi": null,
    "title": "Determination of captopril in human blood and urine by GLC-selected ion monitoring mass spectrometry after oral coadministration with its isotopomer.",
    "abstract": "A modified electron-impact GLC-selected ion monitoring mass spectrometric method for captopril is described. Positive chemical ionization GLC-selected ion monitoring and direct chemical ionization confirms the specificity of this procedure for captopril and establishes the chemical ionization techniques as potential analytical methods. This procedure has been adapted to the simultaneous measurement of captopril and its isotopomer. The results of a pilot oral bioavailability study of four subjects receiving either 100 mg of captopril as a direct compression tablet or a solution concomitantly with a 100-mg solution of isotopomer is discussed.",
    "journal": "Journal of pharmaceutical sciences",
    "date": "1983-02-14",
    "authors": [
      "A I Cohen",
      "R G Devlin",
      "E Ivashkiv",
      "P T Funke",
      "T McCormick"
    ]
  },
  "curators": [
    "Mariia Myshkina",
    "Matthias König"
  ],
  "descriptions": [
    "Pharmacokinetics of captopril administrated as tablet and as solution with its isotopomer."
  ],
