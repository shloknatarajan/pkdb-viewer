  "reference": {
    "pmid": "24721587",
    "doi": null,
    "title": "Lack of effect of colesevelam HCl on the single-dose pharmacokinetics of aspirin, atenolol, enalapril, phenytoin, rosiglitazone, and sitagliptin.",
    "abstract": "Drug interactions with bile acid sequestrants are primarily due to the potential of these agents to bind to concomitant drugs. Six clinical studies were performed to determine the effects of colesevelam on the pharmacokinetics of aspirin, atenolol, enalapril, phenytoin, rosiglitazone, and sitagliptin.",
    "journal": "Diabetes research and clinical practice",
    "date": "2014-11-18",
    "authors": [
      "Ling He",
      "Prachi Wickremasingha",
      "James Lee",
      "Ben Tao",
      "Jeanne Mendell-Harary",
      "Joseph Walker",
      "Douglas Wight"
    ]
  },
  "curators": [
    "Shubhankar Palwankar",
    "Matthias König"
  ],
  "descriptions": [
    "Each study enrolled healthy men and women aged 18–45 years with a body mass index of 18.0–30.0 kg/m2",
    "40 patients enrolled",
    "35 completed the study",
    "A two-period crossover study design",
    "The dose of colesevelam for coadministration with the test drug in each study was 3750 mg (6*625 mg tablets) once daily until the plasma sampling for the test drug was completed",
    "Enalapril 40mg dose alone",
    "Enalapril 40mg plus colesevalam coadministration",
    "Plasma samples for pharmacokinetic analysis were collected just prior to the ﬁrst dose of medication and up to 144 h post-dose",
    "Plasma samples were analyzed by liquid chromatography– tandem mass spectrometry (LC–MS/MS"
  ],
