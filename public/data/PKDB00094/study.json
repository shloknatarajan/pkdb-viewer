  "reference": {
    "pmid": "12194925",
    "doi": null,
    "title": "Plasma and oral fluid pharmacokinetics and pharmacodynamics after oral codeine administration.",
    "abstract": "The disposition of codeine over time was similar in plasma and oral fluid, but because of high variability, oral fluid codeine concentrations did not reliably predict concurrent plasma concentrations. Oral fluid testing is a useful alternative matrix for monitoring codeine exposure with a detection window of 7-21 h for single doses, depending on cutoff concentrations. These controlled drug administration data should aid in the interpretation of oral fluid codeine results.",
    "journal": "Clinical chemistry",
    "date": "2002-09-13",
    "authors": [
      "Insook Kim",
      "Allan J Barnes",
      "Jonathan M Oyler",
      "Raf Schepers",
      "Robert E Joseph",
      "Edward J Cone",
      "Diana Lafko",
      "Eric T Moolchan",
      "Marilyn A Huestis"
    ]
  },
  "curators": [
    "Jan Grzegorzewski",
    "Matthias König"
  ],
  "descriptions": [
    "The disposition of codeine over time was similar in plasma and oral fluid, but because of high variability, oral fluid codeine concentrations did not reliably predict concurrent plasma concentrations. Oral fluid testing is a useful alternative matrix for monitoring codeine exposure with a detection window of 7-21 h for single doses, depending on cutoff concentrations. These controlled drug administration data should aid in the interpretation of oral fluid codeine results."
  ],
