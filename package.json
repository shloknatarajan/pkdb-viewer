    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "prettier": "^3.9.4",
    "typescript": "^5.6.3",
